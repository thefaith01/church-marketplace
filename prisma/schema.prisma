generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MEMBER
  PROVIDER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  FREE
  PAID
}

enum PricingType {
  HOURLY
  FIXED
  QUOTE
}

enum BookingStatus {
  PENDING
  ACCEPTED
  AWAITING_CONFIRMATION
  DECLINED
  COMPLETED
  CANCELLED
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ServiceRequestStatus {
  OPEN
  CLOSED
}

enum ProviderRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile            UserProfile?
  listings           Listing[]
  sentBookings       BookingRequest[] @relation("Requester")
  receivedBookings   BookingRequest[] @relation("Provider")
  conversationsAsOne Conversation[]   @relation("ParticipantOne")
  conversationsAsTwo Conversation[]   @relation("ParticipantTwo")
  messages           Message[]
  resetTokens        PasswordResetToken[]
  reportsMade        Report[]         @relation("ReportsMade")
  reportsReceived    Report[]         @relation("ReportsReceived")
  serviceRequests    ServiceRequest[]
  favorites          Favorite[]
  auditLogs          AuditLog[]       @relation("Auditor")
  savedSearches      SavedSearch[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
  notificationPreference NotificationPreference?
  testimonialsWritten  Testimonial[] @relation("TestimonialsWritten")
  testimonialsReceived Testimonial[] @relation("TestimonialsReceived")
}

model UserProfile {
  id                    String             @id @default(cuid())
  fullName              String
  bio                   String?
  avatarUrl             String?
  role                  Role               @default(MEMBER)
  isChurchLeader        Boolean            @default(false)
  backgroundCheckCleared Boolean           @default(false)
  verifiedAt            DateTime?
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  subscriptionStatus    SubscriptionStatus @default(FREE)
  churchReferenceName   String?
  churchReferenceCity   String?
  churchReferencePerson String?
  churchReferenceLetter String?

  churchId  String?
  church    Church?  @relation(fields: [churchId], references: [id])
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  providerRequests ProviderRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Church {
  id          String       @id @default(cuid())
  name        String
  city        String?
  region      String?
  contactInfo String?
  description String?
  joinCode    String?      @unique
  status      ActiveStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  profiles UserProfile[]
  invites  ChurchInvite[]
  roster   ChurchRosterEntry[]
}

model ChurchInvite {
  id          String    @id @default(cuid())
  churchId    String
  church      Church    @relation(fields: [churchId], references: [id])
  email       String
  token       String    @unique
  invitedById String
  expiresAt   DateTime?
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([churchId])
}

model ChurchRosterEntry {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id])
  email     String
  fullName  String?
  addedById String
  createdAt DateTime @default(now())

  @@unique([churchId, email])
}

model Listing {
  id                String       @id @default(cuid())
  title             String
  category          String
  description       String
  pricingType       PricingType  @default(QUOTE)
  indicativePrice   String?
  serviceArea       String?
  availabilityNotes String?
  status            ActiveStatus @default(ACTIVE)
  featured          Boolean      @default(false)
  isFreeHelp        Boolean      @default(false)
  imageUrl          String?

  providerId String
  provider   User              @relation(fields: [providerId], references: [id])
  bookings   BookingRequest[]
  reports    Report[]
  favorites  Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id            String   @id @default(cuid())
  lastMessageAt DateTime @default(now())

  participantOneId String
  participantOne   User   @relation("ParticipantOne", fields: [participantOneId], references: [id])
  participantTwoId String
  participantTwo   User   @relation("ParticipantTwo", fields: [participantTwoId], references: [id])

  messages  Message[]
  bookings  BookingRequest[]

  createdAt DateTime @default(now())
}

model Message {
  id             String       @id @default(cuid())
  content        String
  readStatus     Boolean      @default(false)
  timestamp      DateTime     @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
}

model Report {
  id             String       @id @default(cuid())
  reason         String
  details        String?
  status         ReportStatus @default(OPEN)

  reporterId     String
  reporter       User         @relation("ReportsMade", fields: [reporterId], references: [id])

  listingId      String?
  listing        Listing?     @relation(fields: [listingId], references: [id])

  reportedUserId String?
  reportedUser   User?        @relation("ReportsReceived", fields: [reportedUserId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Category {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  icon                    String?
  sortOrder               Int      @default(0)
  requiresBackgroundCheck Boolean  @default(false)
  createdAt               DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model ServiceRequest {
  id          String               @id @default(cuid())
  title       String
  category    String?
  description String
  serviceArea String?
  budget      String?
  status      ServiceRequestStatus @default(OPEN)

  requesterId String
  requester   User                 @relation(fields: [requesterId], references: [id])

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model ProviderRequest {
  id           String                @id @default(cuid())
  status       ProviderRequestStatus @default(PENDING)
  note         String?
  documentPath String?
  profileId    String
  profile      UserProfile           @relation(fields: [profileId], references: [id])
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation("Auditor", fields: [actorId], references: [id])
  action    String
  detail    String?
  createdAt DateTime @default(now())
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  label       String?
  keyword     String?
  category    String?
  serviceArea String?
  pricingType String?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String?
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  messagesEmail     Boolean @default(true)
  messagesPush      Boolean @default(true)
  bookingsEmail     Boolean @default(true)
  bookingsPush      Boolean @default(true)
  verificationEmail Boolean @default(true)
  verificationPush  Boolean @default(true)
  requestsEmail     Boolean @default(true)
  requestsPush      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model BookingRequest {
  id                String        @id @default(cuid())
  jobDescription    String
  requestedDate     DateTime?
  requestedDateText String?
  status            BookingStatus @default(PENDING)

  listingId      String
  listing        Listing       @relation(fields: [listingId], references: [id])
  requesterId    String
  requester      User          @relation("Requester", fields: [requesterId], references: [id])
  providerId     String
  provider       User          @relation("Provider", fields: [providerId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  testimonial    Testimonial?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id         String            @id @default(cuid())
  bookingId  String            @unique
  booking    BookingRequest    @relation(fields: [bookingId], references: [id])
  authorId   String
  author     User              @relation("TestimonialsWritten", fields: [authorId], references: [id])
  providerId String
  provider   User              @relation("TestimonialsReceived", fields: [providerId], references: [id])
  content    String
  status     TestimonialStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([providerId, status])
}
