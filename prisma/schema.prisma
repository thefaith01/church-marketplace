generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MEMBER
  PROVIDER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  FREE
  PAID
}

enum PricingType {
  HOURLY
  FIXED
  QUOTE
}

enum BookingStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile            UserProfile?
  listings           Listing[]
  sentBookings       BookingRequest[] @relation("Requester")
  receivedBookings   BookingRequest[] @relation("Provider")
  conversationsAsOne Conversation[]   @relation("ParticipantOne")
  conversationsAsTwo Conversation[]   @relation("ParticipantTwo")
  messages           Message[]
}

model UserProfile {
  id                    String             @id @default(cuid())
  fullName              String
  role                  Role               @default(MEMBER)
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  subscriptionStatus    SubscriptionStatus @default(FREE)
  churchReferenceName   String?
  churchReferenceCity   String?
  churchReferencePerson String?
  churchReferenceLetter String?

  churchId  String?
  church    Church?  @relation(fields: [churchId], references: [id])
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Church {
  id          String       @id @default(cuid())
  name        String
  city        String?
  region      String?
  contactInfo String?
  status      ActiveStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  profiles UserProfile[]
}

model Listing {
  id                String       @id @default(cuid())
  title             String
  category          String
  description       String
  pricingType       PricingType  @default(QUOTE)
  indicativePrice   String?
  serviceArea       String?
  availabilityNotes String?
  status            ActiveStatus @default(ACTIVE)

  providerId String
  provider   User              @relation(fields: [providerId], references: [id])
  bookings   BookingRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id            String   @id @default(cuid())
  lastMessageAt DateTime @default(now())

  participantOneId String
  participantOne   User   @relation("ParticipantOne", fields: [participantOneId], references: [id])
  participantTwoId String
  participantTwo   User   @relation("ParticipantTwo", fields: [participantTwoId], references: [id])

  messages  Message[]
  bookings  BookingRequest[]

  createdAt DateTime @default(now())
}

model Message {
  id             String       @id @default(cuid())
  content        String
  readStatus     Boolean      @default(false)
  timestamp      DateTime     @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
}

model BookingRequest {
  id                String        @id @default(cuid())
  jobDescription    String
  requestedDate     DateTime?
  requestedDateText String?
  status            BookingStatus @default(PENDING)

  listingId      String
  listing        Listing       @relation(fields: [listingId], references: [id])
  requesterId    String
  requester      User          @relation("Requester", fields: [requesterId], references: [id])
  providerId     String
  provider       User          @relation("Provider", fields: [providerId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
